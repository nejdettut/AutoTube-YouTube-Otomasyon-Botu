# ============================================================
#  .env.example — Bu dosyayı kopyala: cp .env.example .env
#  Sonra .env içine gerçek API anahtarlarını yaz
#  .env dosyasını ASLA GitHub'a atma!
# ============================================================

# --- Anthropic (Claude API) ---
# Nereden: https://console.groq.com (100% ÜCRETSİZ)
# Model: llama-3.3-70b-versatile (Türkçe güçlü)
GROQ_API_KEY=gsk_BURAYA_GERCEK_ANAHTARINIZI_YAZIN

# --- ElevenLabs (Seslendirme) ---
# Nereden: https://elevenlabs.io → Profile → API Key
# Ücretsiz: Ayda 10.000 karakter
ELEVENLABS_API_KEY=sk_BURAYA_GERCEK_ANAHTARINIZI_YAZIN

# --- Pexels (Görseller) ---
# Nereden: https://www.pexels.com/api/ → Tamamen ücretsiz
PEXELS_API_KEY=BURAYA_GERCEK_ANAHTARINIZI_YAZIN

# --- YouTube OAuth ---
# Nereden: https://console.cloud.google.com
# Desktop App türünde OAuth 2.0 Client ID oluştur
# JSON dosyasını config/client_secret.json olarak kaydet
YOUTUBE_CLIENT_SECRET_FILE=config/client_secret.json

# --- Dil Ayarı ---
# "tr" = Türkçe video + İngilizce altyazı
# "en" = İngilizce video + Türkçe altyazı
VIDEO_LANGUAGE=tr

# --- ElevenLabs Ses ID ---
# ElevenLabs panelinden beğendiğin sesi seç, ID'sini kopyala
VOICE_ID_TR=pNInz6obpgDQGcFmaJgB
VOICE_ID_EN=21m00Tcm4TlvDq8ikWAM

# --- YouTube Ayarları ---
YOUTUBE_PRIVACY=public
